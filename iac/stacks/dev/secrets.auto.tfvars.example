###############################################################################
# TEMPLATE for local secret values. DO NOT put real tokens in this file.
#
# Setup:
#   cp secrets.auto.tfvars.example secrets.auto.tfvars
#   # edit secrets.auto.tfvars with REAL values
#
# secrets.auto.tfvars is gitignored (*.auto.tfvars) and auto-loaded by Terraform.
# `terraform apply` writes these into AWS Secrets Manager, where External Secrets
# syncs them into the cluster for Jenkins. The real tokens never enter Git.
###############################################################################

github_username = "pratikpagariya"
github_token    = "ghp_REPLACE_WITH_REAL_FINE_GRAINED_PAT"

# Set this AFTER SonarQube is up and you've generated a token in its UI.
# Leave the placeholder for the first apply.
sonarqube_token = "REPLACE_WITH_REAL_SONAR_TOKEN"
